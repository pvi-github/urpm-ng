#: urpm/cli/main.py:628
msgid "Build RPM package(s) in isolated container"
msgstr "Compilar paquete(s) RPM en un contenedor aislado"

#: urpm/cli/main.py:630
msgid ""
"Build RPM packages in isolated containers.\n"
"\n"
"Each build runs in a fresh container that is destroyed after completion,\n"
"ensuring a clean build environment.\n"
"\n"
"Output locations:\n"
"  - .spec files: results go to workspace/RPMS/ and workspace/SRPMS/\n"
"  - .src.rpm files: results go to --output directory (default: ./build-"
"output)\n"
"\n"
"Examples:\n"
"  # Build a spec file (output to ./RPMS/ and ./SRPMS/)\n"
"  urpm build -i mageia:10-build SPECS/foo.spec\n"
"\n"
"  # Build a SRPM (output to ./build-output/foo/)\n"
"  urpm build -i mageia:10-build foo-1.0-1.mga10.src.rpm\n"
"\n"
"  # Build with local dependencies (e.g., libfoo built previously)\n"
"  urpm build -i mageia:10-build SPECS/bar.spec -w 'RPMS/x86_64/libfoo*.rpm'\n"
"\n"
"  # Multiple local dependencies\n"
"  urpm build -i mageia:10-build SPECS/app.spec \\\n"
"      -w 'RPMS/x86_64/libfoo*.rpm' -w 'RPMS/x86_64/libbar*.rpm'\n"
msgstr ""
"Compilar paquetes RPM en contenedores aislados.\n"
"\n"
"Cada compilación se ejecuta en un contenedor nuevo que se destruye al finalizar,\n"
"garantizando un entorno de compilación limpio.\n"
"\n"
"Ubicaciones de salida:\n"
"  - ficheros .spec: los resultados van a workspace/RPMS/ y workspace/SRPMS/\n"
"  - ficheros .src.rpm: los resultados van al directorio --output (predeterminado: ./build-"
"output)\n"
"\n"
"Examples:\n"
"  # Build a spec file (output to ./RPMS/ and ./SRPMS/)\n"
"  urpm build -i mageia:10-build SPECS/foo.spec\n"
"\n"
"  # Build a SRPM (output to ./build-output/foo/)\n"
"  urpm build -i mageia:10-build foo-1.0-1.mga10.src.rpm\n"
"\n"
"  # Build with local dependencies (e.g., libfoo built previously)\n"
"  urpm build -i mageia:10-build SPECS/bar.spec -w 'RPMS/x86_64/libfoo*.rpm'\n"
"\n"
"  # Multiple local dependencies\n"
"  urpm build -i mageia:10-build SPECS/app.spec \\\n"
"      -w 'RPMS/x86_64/libfoo*.rpm' -w 'RPMS/x86_64/libbar*.rpm'\n"

