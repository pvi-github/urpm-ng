"system=use system version, cauldron=use cauldron, auto=remove preference "
"(show current if omitted)"
msgstr ""
"system=Systemversion verwenden, cauldron=cauldron verwenden, auto=Präferenz entfernen "
"(aktuellen Wert anzeigen, wenn weggelassen)"

#: urpm/cli/main.py:1844
msgid "Manage GPG keys for package verification"
msgstr "GPG-Schlüssel zur Paketverifizierung verwalten"

#: urpm/cli/main.py:1849
msgid "List installed GPG keys"
msgstr "Installierte GPG-Schlüssel auflisten"

#: urpm/cli/main.py:1851
msgid "Import GPG key"
msgstr "GPG-Schlüssel importieren"

#: urpm/cli/main.py:1852
msgid "Path to key file or HTTPS URL"
msgstr "Pfad zur Schlüsseldatei oder HTTPS-URL"

#: urpm/cli/main.py:1854
msgid "Remove GPG key"
msgstr "GPG-Schlüssel entfernen"

#: urpm/cli/main.py:1855
msgid "Key ID to remove (e.g., 80420f66)"
msgstr "Zu entfernende Schlüssel-ID (z.B. 80420f66)"

#: urpm/cli/main.py:1862
msgid "Manage P2P peers (provenance, blacklist)"
msgstr "P2P-Peers verwalten (Herkunft, Sperrliste)"

#: urpm/cli/main.py:1873
msgid "List peers and download statistics"
msgstr "Peers und Download-Statistiken auflisten"

#: urpm/cli/main.py:1879
msgid "List packages downloaded from peers"
msgstr "Von Peers heruntergeladene Pakete auflisten"

#: urpm/cli/main.py:1883
msgid "Filter by peer host (optional)"
msgstr "Nach Peer-Host filtern (optional)"

#: urpm/cli/main.py:1887
msgid "Max entries to show (default: 50)"
msgstr "Maximal anzuzeigende Einträge (Standard: 50)"

#: urpm/cli/main.py:1893
msgid "Blacklist a peer"
msgstr "Einen Peer sperren"

#: urpm/cli/main.py:1895
msgid "Peer host to blacklist"
msgstr "Zu sperrender Peer-Host"

#: urpm/cli/main.py:1898 urpm/cli/main.py:1913
msgid "Specific port (default: all ports)"
msgstr "Bestimmter Port (Standard: alle Ports)"

#: urpm/cli/main.py:1902
msgid "Reason for blacklisting"
msgstr "Grund für die Sperrung"

#: urpm/cli/main.py:1908
msgid "Remove peer from blacklist"
msgstr "Peer aus der Sperrliste entfernen"

#: urpm/cli/main.py:1910
msgid "Peer host to unblacklist"
msgstr "Von der Sperrliste zu entfernender Peer-Host"

#: urpm/cli/main.py:1919
msgid "Delete RPMs downloaded from a peer (use after blacklist)"
msgstr "Von einem Peer heruntergeladene RPMs löschen (nach Sperrung verwenden)"

#: urpm/cli/main.py:1921
msgid "Peer host to clean"
msgstr "Zu bereinigender Peer-Host"

#: urpm/cli/main.py:1925
msgid "Do not prompt for confirmation"
msgstr "Nicht zur Bestätigung auffordern"

#: urpm/cli/main.py:1930
msgid "Show all files (do not truncate list)"
msgstr "Alle Dateien anzeigen (Liste nicht kürzen)"

#: urpm/cli/main.py:1938
msgid ""
"Manage AppStream metadata for software centers (Discover, GNOME Software)"
msgstr ""
"AppStream-Metadaten für Software-Center verwalten (Discover, GNOME Software)"

#: urpm/cli/main.py:1948
msgid "Generate AppStream catalog from package database"
msgstr "AppStream-Katalog aus der Paketdatenbank generieren"

#: urpm/cli/main.py:1952
#, python-brace-format
msgid "Output file (default: /var/cache/swcatalog/xml/mageia-{version}.xml.gz)"
msgstr "Ausgabedatei (Standard: /var/cache/swcatalog/xml/mageia-{version}.xml.gz)"

#: urpm/cli/main.py:1957
msgid "Do not gzip the output file"
msgstr "Ausgabedatei nicht mit gzip komprimieren"

#: urpm/cli/main.py:1961
msgid "Generate for specific media only"
msgstr "Nur für bestimmte Medien generieren"

#: urpm/cli/main.py:1967
msgid "Show AppStream status for all media"
msgstr "AppStream-Status für alle Medien anzeigen"

#: urpm/cli/main.py:1973
msgid "Merge per-media AppStream files into unified catalog"
msgstr "AppStream-Dateien pro Medium zu einem einheitlichen Katalog zusammenführen"

#: urpm/cli/main.py:1978
msgid "Also refresh system AppStream cache"
msgstr "Auch den System-AppStream-cache aktualisieren"

#: urpm/cli/main.py:1984
msgid ""
"Create OS metainfo file for AppStream (required for Discover/GNOME Software)"
msgstr ""
"OS-Metainfo-Datei für AppStream erstellen (erforderlich für Discover/GNOME Software)"

#: urpm/cli/main.py:1989
msgid "Overwrite existing metainfo file"
msgstr "Vorhandene Metainfo-Datei überschreiben"

