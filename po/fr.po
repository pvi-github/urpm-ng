#: urpm/cli/main.py:1239
msgid "Add media source"
msgstr "Ajouter une source de médias"

#: urpm/cli/main.py:1241
msgid ""
"Add a media source.\n"
"\n"
"For official Mageia media, just provide the URL:\n"
"  urpm media add https://mirrors.mageia.org/mageia/9/x86_64/media/core/release/\n"
"\n"
"For custom/third-party media, use --custom with name and short_name:\n"
"  urpm media add --custom \"My Repo\" myrepo https://example.com/repo/x86_64/\n"
"\n"
"For legacy mode (non-Mageia URL with explicit name):\n"
"  urpm media add --name \"My Media\" https://example.com/repo/\n"
msgstr ""
"Ajoute une source de médias.\n"
"\n"
"Pour les médias officiels de Mageia, fournir simplement l'URL :\n"
"  urpm media add https://mirrors.mageia.org/mageia/9/x86_64/media/core/release/\n"
"\n"
"Pour des médias personnalisés ou tiers, utiliser --custom avec le nom et le nom court :\n"
"  urpm media add --custom \"My Repo\" myrepo https://example.com/repo/x86_64/\n"
"\n"
"Pour le mode hérité (URL non-Mageia avec nom explicite) :\n"
"  urpm media add --name \"My Media\" https://example.com/repo/\n"

#: urpm/cli/main.py:1253
msgid "Media URL"
msgstr "URL du média"

#: urpm/cli/main.py:1256
msgid "Media name (legacy mode, for non-Mageia URLs without --custom)"
msgstr "Nom du média (mode hérité, pour les URL non-Mageia sans --custom)"

#: urpm/cli/main.py:1262
